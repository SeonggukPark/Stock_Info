# Copy to .env and fill only the providers you want to use.

# Data APIs
FMP_API_KEY=
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
FRED_API_KEY=

# Gmail SMTP. Use a Gmail app password, not your normal account password.
SMTP_USER=
SMTP_APP_PASSWORD=
MAIL_TO=

# Optional: override Edge/Chrome path for PDF printing.
BROWSER_PATH=
